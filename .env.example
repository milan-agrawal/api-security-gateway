# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
PROTECTED_BACKEND_DATABASE_URL=postgresql://username:password@localhost:5432/protected_backend_database
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-here


ACCESS_COOKIE_NAME=
USER_ACCESS_COOKIE_NAME=
ADMIN_ACCESS_COOKIE_NAME=
AUTH_COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=

# Gmail SMTP Configuration for sending emails
# For Gmail, you need to:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Generate an "App Password" from https://myaccount.google.com/apppasswords
# 3. Use the App Password (not your regular Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=your-email@gmail.com

# Note: SMTP_USER should be your full Gmail address
# Note: SMTP_PASSWORD should be the 16-character App Password (without spaces)
# Example: abcd efgh ijkl mnop becomes abcdefghijklmnop

ENCRYPTION_KEY=your-encryption-key-here

SUPPORT_ATTACHMENT_STORAGE_ROOT=
